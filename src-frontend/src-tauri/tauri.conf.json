{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "LlamaStudio",
    "version": "0.1.0",
    "identifier": "com.kmalee.llamastudio",
    "build": {
        "beforeDevCommand": "pnpm run dev",
        "beforeBuildCommand": "pnpm run build",
        "devUrl": "http://127.0.0.1:6767",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [],
        "security": {
            "capabilities": [
                "main-capability"
            ]
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "appimage",
            "deb",
            "rpm",
            "nsis",
            "msi",
            "app",
            "dmg"
        ],
        "createUpdaterArtifacts": true,
        "category": "Utility",
        "shortDescription": "Local-first desktop app for llama.cpp",
        "longDescription": "LlamaStudio is a local-first desktop app for llama.cpp with chat, model management, analytics, and setup guidance.",
        "publisher": "LlamaStudio",
        "homepage": "https://github.com/KM-Alee/llama-studio",
        "copyright": "Copyright © 2026 AI Studio Contributors",
        "license": "MIT",
        "licenseFile": "../../LICENSE",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "plugins": {
        "updater": {
            "pubkey": "${LLAMASTUDIO_UPDATER_PUBKEY}",
            "endpoints": [
                "https://github.com/KM-Alee/llama-studio/releases/latest/download/latest.json"
            ],
            "windows": {
                "installMode": "passive"
            }
        }
    }
}
