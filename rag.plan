}
```

### 7. `src-backend/src/state.rs` — Modify

Add to existing `AppState`:

```rust
pub struct AppState {
    // ... existing fields ...
    pub rag_embedder: Arc<dyn Embedder>,
    pub rag_vectorstore: Arc<RwLock<VectorStore>>,
